[
  {
    "id": "HY-EM-001",
    "cat": "Emergency",
    "sub": "Core Approach",
    "title": "🚑 ABCDE APPROACH",
    "img": "images/highyield/abcde-main.png",
    "content": "Start with the unstable patient, not the final diagnosis.<br><br><span class=\"hl-red\">A</span> Airway<br>• Can the patient speak<br>• Look for obstruction<br>• Protect cervical spine if trauma<br><br><span class=\"hl-blue\">B</span> Breathing<br>• Respiratory rate<br>• Oxygen saturation<br>• Chest rise<br>• Breath sounds<br><br><span class=\"hl-green\">C</span> Circulation<br>• Pulse and blood pressure<br>• Capillary refill<br>• Active bleeding<br>• IV access<br><br><b>D</b> Disability<br>• GCS<br>• Pupils<br>• Blood glucose<br><br><b>E</b> Exposure<br>• Full body exam<br>• Look for hidden injuries<br>• Prevent hypothermia<br><br><br><div style=\"border:1px solid #e5e7eb;border-radius:12px;padding:14px;background:#f8fbff;\"><b>Quick Flow</b><br><br><svg viewBox=\"0 0 700 140\" width=\"100%\" height=\"140\" xmlns=\"http://www.w3.org/2000/svg\"><rect x=\"10\" y=\"35\" width=\"110\" height=\"50\" rx=\"12\" fill=\"#fee2e2\" stroke=\"#ef4444\"/><text x=\"65\" y=\"65\" text-anchor=\"middle\" font-size=\"20\" fill=\"#991b1b\">Airway</text><rect x=\"145\" y=\"35\" width=\"120\" height=\"50\" rx=\"12\" fill=\"#dbeafe\" stroke=\"#2563eb\"/><text x=\"205\" y=\"65\" text-anchor=\"middle\" font-size=\"20\" fill=\"#1d4ed8\">Breathing</text><rect x=\"290\" y=\"35\" width=\"125\" height=\"50\" rx=\"12\" fill=\"#dcfce7\" stroke=\"#16a34a\"/><text x=\"352\" y=\"65\" text-anchor=\"middle\" font-size=\"20\" fill=\"#166534\">Circulation</text><rect x=\"440\" y=\"35\" width=\"115\" height=\"50\" rx=\"12\" fill=\"#f3e8ff\" stroke=\"#8b5cf6\"/><text x=\"497\" y=\"65\" text-anchor=\"middle\" font-size=\"20\" fill=\"#6d28d9\">Disability</text><rect x=\"580\" y=\"35\" width=\"100\" height=\"50\" rx=\"12\" fill=\"#fef3c7\" stroke=\"#f59e0b\"/><text x=\"630\" y=\"65\" text-anchor=\"middle\" font-size=\"20\" fill=\"#92400e\">Exposure</text><line x1=\"120\" y1=\"60\" x2=\"145\" y2=\"60\" stroke=\"#475569\" stroke-width=\"3\"/><line x1=\"265\" y1=\"60\" x2=\"290\" y2=\"60\" stroke=\"#475569\" stroke-width=\"3\"/><line x1=\"415\" y1=\"60\" x2=\"440\" y2=\"60\" stroke=\"#475569\" stroke-width=\"3\"/><line x1=\"555\" y1=\"60\" x2=\"580\" y2=\"60\" stroke=\"#475569\" stroke-width=\"3\"/></svg></div><br><div style=\"overflow-x:auto;\"><table><thead><tr><th>Step</th><th>Main focus</th><th>Immediate action</th></tr></thead><tbody><tr><td>A</td><td>Patent airway</td><td>Suction, airway maneuver</td></tr><tr><td>B</td><td>Oxygenation</td><td>Oxygen, auscultation</td></tr><tr><td>C</td><td>Perfusion</td><td>IV access, fluids, stop bleeding</td></tr><tr><td>D</td><td>Neurologic status</td><td>GCS, pupils, glucose</td></tr><tr><td>E</td><td>Full inspection</td><td>Expose, keep warm</td></tr></tbody></table></div>",
    "quiz": {
      "q": "What is the first priority in any unstable trauma patient?",
      "a": "Airway with cervical spine protection."
    }
  },
  {
    "id": "HY-EM-002",
    "cat": "Emergency",
    "sub": "Shock",
    "title": "🩸 SHOCK OVERVIEW",
    "img": "images/highyield/shock-types.png",
    "content": "Shock means inadequate tissue perfusion.<br><br><span class=\"hl-red\">Hypovolemic shock</span><br>• Hemorrhage or fluid loss<br>• Cold, clammy skin<br>• Tachycardia<br><br><span class=\"hl-blue\">Septic shock</span><br>• Infection source<br>• Warm extremities early<br>• Vasodilation<br>• High lactate<br><br><span class=\"hl-green\">Cardiogenic shock</span><br>• Pump failure<br>• Often after MI<br>• Pulmonary edema may coexist<br><br><b>Obstructive shock</b><br>• PE<br>• Cardiac tamponade<br>• Tension pneumothorax<br><br><div style=\"border:1px solid #e5e7eb;border-radius:12px;padding:14px;background:#fff;\"><b>Exam Memory Map</b><br><br><svg viewBox=\"0 0 700 220\" width=\"100%\" height=\"220\" xmlns=\"http://www.w3.org/2000/svg\"><rect x=\"260\" y=\"10\" width=\"180\" height=\"50\" rx=\"12\" fill=\"#0f172a\"/><text x=\"350\" y=\"42\" text-anchor=\"middle\" font-size=\"22\" fill=\"white\">SHOCK</text><line x1=\"350\" y1=\"60\" x2=\"100\" y2=\"105\" stroke=\"#475569\" stroke-width=\"3\"/><line x1=\"350\" y1=\"60\" x2=\"260\" y2=\"105\" stroke=\"#475569\" stroke-width=\"3\"/><line x1=\"350\" y1=\"60\" x2=\"440\" y2=\"105\" stroke=\"#475569\" stroke-width=\"3\"/><line x1=\"350\" y1=\"60\" x2=\"600\" y2=\"105\" stroke=\"#475569\" stroke-width=\"3\"/><rect x=\"20\" y=\"105\" width=\"160\" height=\"70\" rx=\"12\" fill=\"#fee2e2\" stroke=\"#ef4444\"/><text x=\"100\" y=\"135\" text-anchor=\"middle\" font-size=\"18\" fill=\"#991b1b\">Hypovolemic</text><text x=\"100\" y=\"160\" text-anchor=\"middle\" font-size=\"15\" fill=\"#991b1b\">Bleeding / fluid loss</text><rect x=\"190\" y=\"105\" width=\"160\" height=\"70\" rx=\"12\" fill=\"#dbeafe\" stroke=\"#2563eb\"/><text x=\"270\" y=\"135\" text-anchor=\"middle\" font-size=\"18\" fill=\"#1d4ed8\">Septic</text><text x=\"270\" y=\"160\" text-anchor=\"middle\" font-size=\"15\" fill=\"#1d4ed8\">Warm early</text><rect x=\"360\" y=\"105\" width=\"160\" height=\"70\" rx=\"12\" fill=\"#dcfce7\" stroke=\"#16a34a\"/><text x=\"440\" y=\"135\" text-anchor=\"middle\" font-size=\"18\" fill=\"#166534\">Cardiogenic</text><text x=\"440\" y=\"160\" text-anchor=\"middle\" font-size=\"15\" fill=\"#166534\">Pump failure</text><rect x=\"530\" y=\"105\" width=\"160\" height=\"70\" rx=\"12\" fill=\"#fef3c7\" stroke=\"#f59e0b\"/><text x=\"610\" y=\"135\" text-anchor=\"middle\" font-size=\"18\" fill=\"#92400e\">Obstructive</text><text x=\"610\" y=\"160\" text-anchor=\"middle\" font-size=\"15\" fill=\"#92400e\">PE / tamponade / tension PTX</text></svg></div><br><div style=\"overflow-x:auto;\"><table><thead><tr><th>Type</th><th>Skin</th><th>Main clue</th></tr></thead><tbody><tr><td>Hypovolemic</td><td>Cold</td><td>Bleeding or severe fluid loss</td></tr><tr><td>Septic</td><td>Warm early</td><td>Infection + hypotension</td></tr><tr><td>Cardiogenic</td><td>Cold</td><td>MI or pump failure</td></tr><tr><td>Obstructive</td><td>Cold</td><td>Mechanical blockage of circulation</td></tr></tbody></table></div>",
    "quiz": {
      "q": "Which type of shock typically has warm extremities early?",
      "a": "Septic shock."
    }
  },
  {
    "id": "HY-EM-003",
    "cat": "Emergency",
    "sub": "Respiratory Emergencies",
    "title": "🌬️ TENSION PNEUMOTHORAX",
    "img": "images/highyield/tension-pneumothorax.png",
    "content": "This is an immediate life threat.<br><br><span class=\"hl-red\">Classic findings</span><br>• Sudden severe dyspnea<br>• Hypotension<br>• Reduced breath sounds on one side<br>• Tracheal deviation<br>• Distended neck veins may appear<br><br><span class=\"hl-green\">Immediate treatment</span><br>• Needle decompression first<br>• Chest tube after stabilization<br><br><div style=\"border:1px solid #e5e7eb;border-radius:12px;padding:14px;background:#f8fbff;\"><b>One-minute diagram</b><br><br><svg viewBox=\"0 0 760 260\" width=\"100%\" height=\"260\" xmlns=\"http://www.w3.org/2000/svg\"><rect x=\"20\" y=\"20\" width=\"300\" height=\"200\" rx=\"16\" fill=\"#dbeafe\" stroke=\"#2563eb\"/><text x=\"170\" y=\"45\" text-anchor=\"middle\" font-size=\"22\" fill=\"#1d4ed8\">Normal chest</text><ellipse cx=\"120\" cy=\"130\" rx=\"55\" ry=\"80\" fill=\"#bfdbfe\" stroke=\"#1d4ed8\"/><ellipse cx=\"220\" cy=\"130\" rx=\"55\" ry=\"80\" fill=\"#bfdbfe\" stroke=\"#1d4ed8\"/><line x1=\"170\" y1=\"70\" x2=\"170\" y2=\"190\" stroke=\"#334155\" stroke-width=\"6\"/><rect x=\"440\" y=\"20\" width=\"300\" height=\"200\" rx=\"16\" fill=\"#fee2e2\" stroke=\"#ef4444\"/><text x=\"590\" y=\"45\" text-anchor=\"middle\" font-size=\"22\" fill=\"#991b1b\">Tension pneumothorax</text><ellipse cx=\"520\" cy=\"130\" rx=\"35\" ry=\"80\" fill=\"#fecaca\" stroke=\"#b91c1c\"/><ellipse cx=\"645\" cy=\"130\" rx=\"55\" ry=\"80\" fill=\"#bfdbfe\" stroke=\"#1d4ed8\"/><line x1=\"585\" y1=\"70\" x2=\"585\" y2=\"190\" stroke=\"#334155\" stroke-width=\"6\"/><line x1=\"585\" y1=\"70\" x2=\"565\" y2=\"190\" stroke=\"#334155\" stroke-width=\"0\"/><text x=\"590\" y=\"220\" text-anchor=\"middle\" font-size=\"16\" fill=\"#991b1b\">Collapsed lung + mediastinal shift</text><line x1=\"320\" y1=\"120\" x2=\"440\" y2=\"120\" stroke=\"#475569\" stroke-width=\"4\"/><polygon points=\"440,120 420,110 420,130\" fill=\"#475569\"/></svg></div><br><div style=\"overflow-x:auto;\"><table><thead><tr><th>Feature</th><th>Tension pneumothorax</th></tr></thead><tbody><tr><td>Breath sounds</td><td>Reduced on affected side</td></tr><tr><td>Blood pressure</td><td>Low</td></tr><tr><td>Neck veins</td><td>May be distended</td></tr><tr><td>Action</td><td>Needle decompression now</td></tr></tbody></table></div>",
    "quiz": {
      "q": "Should you wait for a chest X-ray if tension pneumothorax is clinically obvious?",
      "a": "No. Treat immediately with decompression."
    }
  },
  {
    "id": "HY-EM-004",
    "cat": "Emergency",
    "sub": "Sepsis",
    "title": "🦠 SEPSIS BUNDLE",
    "img": "images/highyield/sepsis-bundle.png",
    "content": "Suspect sepsis when infection is followed by organ dysfunction or shock.<br><br><span class=\"hl-red\">Red flags</span><br>• Hypotension<br>• Altered mental status<br>• Tachycardia<br>• Fever or hypothermia<br>• High lactate<br><br><span class=\"hl-green\">Early management</span><br>• ABCs<br>• Blood cultures if possible<br>• Broad-spectrum antibiotics early<br>• IV crystalloids<br>• Repeat perfusion assessment<br><br><div style=\"border:1px solid #e5e7eb;border-radius:12px;padding:14px;background:#fff;\"><b>Sepsis flowchart</b><br><br><svg viewBox=\"0 0 700 330\" width=\"100%\" height=\"330\" xmlns=\"http://www.w3.org/2000/svg\"><rect x=\"210\" y=\"10\" width=\"280\" height=\"50\" rx=\"12\" fill=\"#fee2e2\" stroke=\"#ef4444\"/><text x=\"350\" y=\"42\" text-anchor=\"middle\" font-size=\"20\" fill=\"#991b1b\">Suspected infection + instability</text><line x1=\"350\" y1=\"60\" x2=\"350\" y2=\"95\" stroke=\"#475569\" stroke-width=\"3\"/><rect x=\"220\" y=\"95\" width=\"260\" height=\"50\" rx=\"12\" fill=\"#dbeafe\" stroke=\"#2563eb\"/><text x=\"350\" y=\"127\" text-anchor=\"middle\" font-size=\"18\" fill=\"#1d4ed8\">Draw cultures if it will not delay care</text><line x1=\"350\" y1=\"145\" x2=\"350\" y2=\"180\" stroke=\"#475569\" stroke-width=\"3\"/><rect x=\"220\" y=\"180\" width=\"260\" height=\"50\" rx=\"12\" fill=\"#dcfce7\" stroke=\"#16a34a\"/><text x=\"350\" y=\"212\" text-anchor=\"middle\" font-size=\"18\" fill=\"#166534\">Start broad-spectrum antibiotics</text><line x1=\"350\" y1=\"230\" x2=\"350\" y2=\"265\" stroke=\"#475569\" stroke-width=\"3\"/><rect x=\"220\" y=\"265\" width=\"260\" height=\"50\" rx=\"12\" fill=\"#fef3c7\" stroke=\"#f59e0b\"/><text x=\"350\" y=\"297\" text-anchor=\"middle\" font-size=\"18\" fill=\"#92400e\">Give IV fluids and reassess</text></svg></div><br><div style=\"overflow-x:auto;\"><table><thead><tr><th>Step</th><th>Why it matters</th></tr></thead><tbody><tr><td>Antibiotics early</td><td>Reduces mortality</td></tr><tr><td>Fluids</td><td>Improves perfusion</td></tr><tr><td>Lactate</td><td>Marker of hypoperfusion</td></tr><tr><td>Reassessment</td><td>Guides vasopressors and escalation</td></tr></tbody></table></div>",
    "quiz": {
      "q": "What is one of the most time-sensitive treatments in sepsis?",
      "a": "Early broad-spectrum antibiotics."
    }
  },
  {
    "id": "HY-EM-005",
    "cat": "Emergency",
    "sub": "Endocrine Emergencies",
    "title": "🍬 DKA VS HYPOGLYCEMIA",
    "img": "images/highyield/dka-vs-hypo.png",
    "content": "Two exam favorites that must be separated fast.<br><br><div style=\"overflow-x:auto;\"><table><thead><tr><th>Feature</th><th>DKA</th><th>Hypoglycemia</th></tr></thead><tbody><tr><td>Glucose</td><td>High</td><td>Low</td></tr><tr><td>Mental status</td><td>Confused or drowsy</td><td>Confused, sweaty, shaky</td></tr><tr><td>Breathing</td><td>Kussmaul breathing may occur</td><td>Usually no acidotic breathing</td></tr><tr><td>Ketones</td><td>Present</td><td>Absent</td></tr><tr><td>Immediate treatment</td><td>IV fluids + insulin + potassium monitoring</td><td>Give glucose now</td></tr></tbody></table></div><br><div style=\"border:1px solid #e5e7eb;border-radius:12px;padding:14px;background:#f8fbff;\"><b>Decision pathway</b><br><br><svg viewBox=\"0 0 700 250\" width=\"100%\" height=\"250\" xmlns=\"http://www.w3.org/2000/svg\"><rect x=\"220\" y=\"10\" width=\"260\" height=\"50\" rx=\"12\" fill=\"#0f172a\"/><text x=\"350\" y=\"42\" text-anchor=\"middle\" font-size=\"20\" fill=\"white\">Diabetic patient is unwell</text><line x1=\"350\" y1=\"60\" x2=\"350\" y2=\"95\" stroke=\"#475569\" stroke-width=\"3\"/><rect x=\"245\" y=\"95\" width=\"210\" height=\"50\" rx=\"12\" fill=\"#dbeafe\" stroke=\"#2563eb\"/><text x=\"350\" y=\"127\" text-anchor=\"middle\" font-size=\"18\" fill=\"#1d4ed8\">Check blood glucose</text><line x1=\"350\" y1=\"145\" x2=\"220\" y2=\"185\" stroke=\"#475569\" stroke-width=\"3\"/><line x1=\"350\" y1=\"145\" x2=\"480\" y2=\"185\" stroke=\"#475569\" stroke-width=\"3\"/><rect x=\"70\" y=\"185\" width=\"220\" height=\"50\" rx=\"12\" fill=\"#fee2e2\" stroke=\"#ef4444\"/><text x=\"180\" y=\"217\" text-anchor=\"middle\" font-size=\"18\" fill=\"#991b1b\">Low glucose → give glucose</text><rect x=\"410\" y=\"185\" width=\"220\" height=\"50\" rx=\"12\" fill=\"#dcfce7\" stroke=\"#16a34a\"/><text x=\"520\" y=\"217\" text-anchor=\"middle\" font-size=\"18\" fill=\"#166534\">High glucose + acidosis → DKA</text></svg></div>",
    "quiz": {
      "q": "What must be monitored closely after starting insulin in DKA?",
      "a": "Potassium."
    }
  }{
"id":"HY-EM-006",
"cat":"Emergency",
"sub":"Cardiac",
"title":"⚡ CARDIAC ARREST RHYTHMS",
"content":"Four rhythms must be recognized immediately in emergency medicine.<br><br><span class=\"hl-red\">Shockable rhythms</span><br>• Ventricular fibrillation (VF)<br>• Pulseless ventricular tachycardia (VT)<br><br><span class=\"hl-blue\">Non-shockable rhythms</span><br>• Asystole<br>• Pulseless electrical activity (PEA)<br><br><table><thead><tr><th>Rhythm</th><th>Treatment</th></tr></thead><tbody><tr><td>VF</td><td>Defibrillation + CPR</td></tr><tr><td>Pulseless VT</td><td>Defibrillation + CPR</td></tr><tr><td>Asystole</td><td>CPR + Epinephrine</td></tr><tr><td>PEA</td><td>CPR + Treat cause</td></tr></tbody></table>",
"quiz":{
"q":"Which cardiac arrest rhythms require defibrillation?",
"a":"Ventricular fibrillation and pulseless ventricular tachycardia."
}
}
]
