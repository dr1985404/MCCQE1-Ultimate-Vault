[
  {
    "id": "HY-EM-001",
    "cat": "Emergency",
    "sub": "Core Approach",
    "title": "🚑 ABCDE APPROACH",
    "content": "Start with the unstable patient, not the final diagnosis.<br><br><span class=\"hl-red\">A</span> Airway<br>• Can the patient speak<br>• Look for obstruction<br>• Protect cervical spine if trauma<br><br><span class=\"hl-blue\">B</span> Breathing<br>• Respiratory rate<br>• Oxygen saturation<br>• Chest rise<br>• Breath sounds<br><br><span class=\"hl-green\">C</span> Circulation<br>• Pulse and blood pressure<br>• Capillary refill<br>• Active bleeding<br>• IV access<br><br><b>D</b> Disability<br>• GCS<br>• Pupils<br>• Blood glucose<br><br><b>E</b> Exposure<br>• Full body exam<br>• Look for hidden injuries<br>• Prevent hypothermia<br><br><br><div style=\"border:1px solid #e5e7eb;border-radius:12px;padding:14px;background:#f8fbff;\"><b>Quick Flow</b><br><br><svg viewBox=\"0 0 700 140\" width=\"100%\" height=\"140\" xmlns=\"http://www.w3.org/2000/svg\"><rect x=\"10\" y=\"35\" width=\"110\" height=\"50\" rx=\"12\" fill=\"#fee2e2\" stroke=\"#ef4444\"/><text x=\"65\" y=\"65\" text-anchor=\"middle\" font-size=\"20\" fill=\"#991b1b\">Airway</text><rect x=\"145\" y=\"35\" width=\"120\" height=\"50\" rx=\"12\" fill=\"#dbeafe\" stroke=\"#2563eb\"/><text x=\"205\" y=\"65\" text-anchor=\"middle\" font-size=\"20\" fill=\"#1d4ed8\">Breathing</text><rect x=\"290\" y=\"35\" width=\"125\" height=\"50\" rx=\"12\" fill=\"#dcfce7\" stroke=\"#16a34a\"/><text x=\"352\" y=\"65\" text-anchor=\"middle\" font-size=\"20\" fill=\"#166534\">Circulation</text><rect x=\"440\" y=\"35\" width=\"115\" height=\"50\" rx=\"12\" fill=\"#f3e8ff\" stroke=\"#8b5cf6\"/><text x=\"497\" y=\"65\" text-anchor=\"middle\" font-size=\"20\" fill=\"#6d28d9\">Disability</text><rect x=\"580\" y=\"35\" width=\"100\" height=\"50\" rx=\"12\" fill=\"#fef3c7\" stroke=\"#f59e0b\"/><text x=\"630\" y=\"65\" text-anchor=\"middle\" font-size=\"20\" fill=\"#92400e\">Exposure</text><line x1=\"120\" y1=\"60\" x2=\"145\" y2=\"60\" stroke=\"#475569\" stroke-width=\"3\"/><line x1=\"265\" y1=\"60\" x2=\"290\" y2=\"60\" stroke=\"#475569\" stroke-width=\"3\"/><line x1=\"415\" y1=\"60\" x2=\"440\" y2=\"60\" stroke=\"#475569\" stroke-width=\"3\"/><line x1=\"555\" y1=\"60\" x2=\"580\" y2=\"60\" stroke=\"#475569\" stroke-width=\"3\"/></svg></div><br><div style=\"overflow-x:auto;\"><table><thead><tr><th>Step</th><th>Main focus</th><th>Immediate action</th></tr></thead><tbody><tr><td>A</td><td>Patent airway</td><td>Suction, airway maneuver</td></tr><tr><td>B</td><td>Oxygenation</td><td>Oxygen, auscultation</td></tr><tr><td>C</td><td>Perfusion</td><td>IV access, fluids, stop bleeding</td></tr><tr><td>D</td><td>Neurologic status</td><td>GCS, pupils, glucose</td></tr><tr><td>E</td><td>Full inspection</td><td>Expose, keep warm</td></tr></tbody></table></div>",
    "quiz": {
      "q": "What is the first priority in any unstable trauma patient?",
      "a": "Airway with cervical spine protection."
    }
  },
  {
    "id": "HY-EM-002",
    "cat": "Emergency",
    "sub": "Shock",
    "title": "🩸 SHOCK OVERVIEW",
    "content": "Shock means inadequate tissue perfusion.<br><br><span class=\"hl-red\">Hypovolemic shock</span><br>• Hemorrhage or fluid loss<br>• Cold, clammy skin<br>• Tachycardia<br><br><span class=\"hl-blue\">Septic shock</span><br>• Infection source<br>• Warm extremities early<br>• Vasodilation<br>• High lactate<br><br><span class=\"hl-green\">Cardiogenic shock</span><br>• Pump failure<br>• Often after MI<br>• Pulmonary edema may coexist<br><br><b>Obstructive shock</b><br>• PE<br>• Cardiac tamponade<br>• Tension pneumothorax<br><br><div style=\"border:1px solid #e5e7eb;border-radius:12px;padding:14px;background:#fff;\"><b>Exam Memory Map</b><br><br><svg viewBox=\"0 0 700 220\" width=\"100%\" height=\"220\" xmlns=\"http://www.w3.org/2000/svg\"><rect x=\"260\" y=\"10\" width=\"180\" height=\"50\" rx=\"12\" fill=\"#0f172a\"/><text x=\"350\" y=\"42\" text-anchor=\"middle\" font-size=\"22\" fill=\"white\">SHOCK</text><line x1=\"350\" y1=\"60\" x2=\"100\" y2=\"105\" stroke=\"#475569\" stroke-width=\"3\"/><line x1=\"350\" y1=\"60\" x2=\"260\" y2=\"105\" stroke=\"#475569\" stroke-width=\"3\"/><line x1=\"350\" y1=\"60\" x2=\"440\" y2=\"105\" stroke=\"#475569\" stroke-width=\"3\"/><line x1=\"350\" y1=\"60\" x2=\"600\" y2=\"105\" stroke=\"#475569\" stroke-width=\"3\"/><rect x=\"20\" y=\"105\" width=\"160\" height=\"70\" rx=\"12\" fill=\"#fee2e2\" stroke=\"#ef4444\"/><text x=\"100\" y=\"135\" text-anchor=\"middle\" font-size=\"18\" fill=\"#991b1b\">Hypovolemic</text><text x=\"100\" y=\"160\" text-anchor=\"middle\" font-size=\"15\" fill=\"#991b1b\">Bleeding / fluid loss</text><rect x=\"190\" y=\"105\" width=\"160\" height=\"70\" rx=\"12\" fill=\"#dbeafe\" stroke=\"#2563eb\"/><text x=\"270\" y=\"135\" text-anchor=\"middle\" font-size=\"18\" fill=\"#1d4ed8\">Septic</text><text x=\"270\" y=\"160\" text-anchor=\"middle\" font-size=\"15\" fill=\"#1d4ed8\">Warm early</text><rect x=\"360\" y=\"105\" width=\"160\" height=\"70\" rx=\"12\" fill=\"#dcfce7\" stroke=\"#16a34a\"/><text x=\"440\" y=\"135\" text-anchor=\"middle\" font-size=\"18\" fill=\"#166534\">Cardiogenic</text><text x=\"440\" y=\"160\" text-anchor=\"middle\" font-size=\"15\" fill=\"#166534\">Pump failure</text><rect x=\"530\" y=\"105\" width=\"160\" height=\"70\" rx=\"12\" fill=\"#fef3c7\" stroke=\"#f59e0b\"/><text x=\"610\" y=\"135\" text-anchor=\"middle\" font-size=\"18\" fill=\"#92400e\">Obstructive</text><text x=\"610\" y=\"160\" text-anchor=\"middle\" font-size=\"15\" fill=\"#92400e\">PE / tamponade / tension PTX</text></svg></div><br><div style=\"overflow-x:auto;\"><table><thead><tr><th>Type</th><th>Skin</th><th>Main clue</th></tr></thead><tbody><tr><td>Hypovolemic</td><td>Cold</td><td>Bleeding or severe fluid loss</td></tr><tr><td>Septic</td><td>Warm early</td><td>Infection + hypotension</td></tr><tr><td>Cardiogenic</td><td>Cold</td><td>MI or pump failure</td></tr><tr><td>Obstructive</td><td>Cold</td><td>Mechanical blockage of circulation</td></tr></tbody></table></div>",
    "quiz": {
      "q": "Which type of shock typically has warm extremities early?",
      "a": "Septic shock."
    }
  },
  {
    "id": "HY-EM-003",
    "cat": "Emergency",
    "sub": "Respiratory Emergencies",
    "title": "🌬️ TENSION PNEUMOTHORAX",
    "content": "This is an immediate life threat.<br><br><span class=\"hl-red\">Classic findings</span><br>• Sudden severe dyspnea<br>• Hypotension<br>• Reduced breath sounds on one side<br>• Tracheal deviation<br>• Distended neck veins may appear<br><br><span class=\"hl-green\">Immediate treatment</span><br>• Needle decompression first<br>• Chest tube after stabilization<br><br><div style=\"border:1px solid #e5e7eb;border-radius:12px;padding:14px;background:#f8fbff;\"><b>One-minute diagram</b><br><br><svg viewBox=\"0 0 760 260\" width=\"100%\" height=\"260\" xmlns=\"http://www.w3.org/2000/svg\"><rect x=\"20\" y=\"20\" width=\"300\" height=\"200\" rx=\"16\" fill=\"#dbeafe\" stroke=\"#2563eb\"/><text x=\"170\" y=\"45\" text-anchor=\"middle\" font-size=\"22\" fill=\"#1d4ed8\">Normal chest</text><ellipse cx=\"120\" cy=\"130\" rx=\"55\" ry=\"80\" fill=\"#bfdbfe\" stroke=\"#1d4ed8\"/><ellipse cx=\"220\" cy=\"130\" rx=\"55\" ry=\"80\" fill=\"#bfdbfe\" stroke=\"#1d4ed8\"/><line x1=\"170\" y1=\"70\" x2=\"170\" y2=\"190\" stroke=\"#334155\" stroke-width=\"6\"/><rect x=\"440\" y=\"20\" width=\"300\" height=\"200\" rx=\"16\" fill=\"#fee2e2\" stroke=\"#ef4444\"/><text x=\"590\" y=\"45\" text-anchor=\"middle\" font-size=\"22\" fill=\"#991b1b\">Tension pneumothorax</text><ellipse cx=\"520\" cy=\"130\" rx=\"35\" ry=\"80\" fill=\"#fecaca\" stroke=\"#b91c1c\"/><ellipse cx=\"645\" cy=\"130\" rx=\"55\" ry=\"80\" fill=\"#bfdbfe\" stroke=\"#1d4ed8\"/><line x1=\"585\" y1=\"70\" x2=\"585\" y2=\"190\" stroke=\"#334155\" stroke-width=\"6\"/><text x=\"590\" y=\"220\" text-anchor=\"middle\" font-size=\"16\" fill=\"#991b1b\">Collapsed lung + mediastinal shift</text><line x1=\"320\" y1=\"120\" x2=\"440\" y2=\"120\" stroke=\"#475569\" stroke-width=\"4\"/><polygon points=\"440,120 420,110 420,130\" fill=\"#475569\"/></svg></div><br><div style=\"overflow-x:auto;\"><table><thead><tr><th>Feature</th><th>Tension pneumothorax</th></tr></thead><tbody><tr><td>Breath sounds</td><td>Reduced on affected side</td></tr><tr><td>Blood pressure</td><td>Low</td></tr><tr><td>Neck veins</td><td>May be distended</td></tr><tr><td>Action</td><td>Needle decompression now</td></tr></tbody></table></div>",
    "quiz": {
      "q": "Should you wait for a chest X-ray if tension pneumothorax is clinically obvious?",
      "a": "No. Treat immediately with decompression."
    }
  },
  {
    "id": "HY-EM-004",
    "cat": "Emergency",
    "sub": "Sepsis",
    "title": "🦠 SEPSIS BUNDLE",
    "content": "Suspect sepsis when infection is followed by organ dysfunction or shock.<br><br><span class=\"hl-red\">Red flags</span><br>• Hypotension<br>• Altered mental status<br>• Tachycardia<br>• Fever or hypothermia<br>• High lactate<br><br><span class=\"hl-green\">Early management</span><br>• ABCs<br>• Blood cultures if possible<br>• Broad-spectrum antibiotics early<br>• IV crystalloids<br>• Repeat perfusion assessment<br><br><div style=\"border:1px solid #e5e7eb;border-radius:12px;padding:14px;background:#fff;\"><b>Sepsis flowchart</b><br><br><svg viewBox=\"0 0 700 330\" width=\"100%\" height=\"330\" xmlns=\"http://www.w3.org/2000/svg\"><rect x=\"210\" y=\"10\" width=\"280\" height=\"50\" rx=\"12\" fill=\"#fee2e2\" stroke=\"#ef4444\"/><text x=\"350\" y=\"42\" text-anchor=\"middle\" font-size=\"20\" fill=\"#991b1b\">Suspected infection + instability</text><line x1=\"350\" y1=\"60\" x2=\"350\" y2=\"95\" stroke=\"#475569\" stroke-width=\"3\"/><rect x=\"220\" y=\"95\" width=\"260\" height=\"50\" rx=\"12\" fill=\"#dbeafe\" stroke=\"#2563eb\"/><text x=\"350\" y=\"127\" text-anchor=\"middle\" font-size=\"18\" fill=\"#1d4ed8\">Draw cultures if it will not delay care</text><line x1=\"350\" y1=\"145\" x2=\"350\" y2=\"180\" stroke=\"#475569\" stroke-width=\"3\"/><rect x=\"220\" y=\"180\" width=\"260\" height=\"50\" rx=\"12\" fill=\"#dcfce7\" stroke=\"#16a34a\"/><text x=\"350\" y=\"212\" text-anchor=\"middle\" font-size=\"18\" fill=\"#166534\">Start broad-spectrum antibiotics</text><line x1=\"350\" y1=\"230\" x2=\"350\" y2=\"265\" stroke=\"#475569\" stroke-width=\"3\"/><rect x=\"220\" y=\"265\" width=\"260\" height=\"50\" rx=\"12\" fill=\"#fef3c7\" stroke=\"#f59e0b\"/><text x=\"350\" y=\"297\" text-anchor=\"middle\" font-size=\"18\" fill=\"#92400e\">Give IV fluids and reassess</text></svg></div><br><div style=\"overflow-x:auto;\"><table><thead><tr><th>Step</th><th>Why it matters</th></tr></thead><tbody><tr><td>Antibiotics early</td><td>Reduces mortality</td></tr><tr><td>Fluids</td><td>Improves perfusion</td></tr><tr><td>Lactate</td><td>Marker of hypoperfusion</td></tr><tr><td>Reassessment</td><td>Guides vasopressors and escalation</td></tr></tbody></table></div>",
    "quiz": {
      "q": "What is one of the most time-sensitive treatments in sepsis?",
      "a": "Early broad-spectrum antibiotics."
    }
  },
  {
    "id": "HY-EM-005",
    "cat": "Emergency",
    "sub": "Endocrine Emergencies",
    "title": "🍬 DKA VS HYPOGLYCEMIA",
    "content": "Two exam favorites that must be separated fast.<br><br><div style=\"overflow-x:auto;\"><table><thead><tr><th>Feature</th><th>DKA</th><th>Hypoglycemia</th></tr></thead><tbody><tr><td>Glucose</td><td>High</td><td>Low</td></tr><tr><td>Mental status</td><td>Confused or drowsy</td><td>Confused, sweaty, shaky</td></tr><tr><td>Breathing</td><td>Kussmaul breathing may occur</td><td>Usually no acidotic breathing</td></tr><tr><td>Ketones</td><td>Present</td><td>Absent</td></tr><tr><td>Immediate treatment</td><td>IV fluids + insulin + potassium monitoring</td><td>Give glucose now</td></tr></tbody></table></div><br><div style=\"border:1px solid #e5e7eb;border-radius:12px;padding:14px;background:#f8fbff;\"><b>Decision pathway</b><br><br><svg viewBox=\"0 0 700 250\" width=\"100%\" height=\"250\" xmlns=\"http://www.w3.org/2000/svg\"><rect x=\"220\" y=\"10\" width=\"260\" height=\"50\" rx=\"12\" fill=\"#0f172a\"/><text x=\"350\" y=\"42\" text-anchor=\"middle\" font-size=\"20\" fill=\"white\">Diabetic patient is unwell</text><line x1=\"350\" y1=\"60\" x2=\"350\" y2=\"95\" stroke=\"#475569\" stroke-width=\"3\"/><rect x=\"245\" y=\"95\" width=\"210\" height=\"50\" rx=\"12\" fill=\"#dbeafe\" stroke=\"#2563eb\"/><text x=\"350\" y=\"127\" text-anchor=\"middle\" font-size=\"18\" fill=\"#1d4ed8\">Check blood glucose</text><line x1=\"350\" y1=\"145\" x2=\"220\" y2=\"185\" stroke=\"#475569\" stroke-width=\"3\"/><line x1=\"350\" y1=\"145\" x2=\"480\" y2=\"185\" stroke=\"#475569\" stroke-width=\"3\"/><rect x=\"70\" y=\"185\" width=\"220\" height=\"50\" rx=\"12\" fill=\"#fee2e2\" stroke=\"#ef4444\"/><text x=\"180\" y=\"217\" text-anchor=\"middle\" font-size=\"18\" fill=\"#991b1b\">Low glucose → give glucose</text><rect x=\"410\" y=\"185\" width=\"220\" height=\"50\" rx=\"12\" fill=\"#dcfce7\" stroke=\"#16a34a\"/><text x=\"520\" y=\"217\" text-anchor=\"middle\" font-size=\"18\" fill=\"#166534\">High glucose + acidosis → DKA</text></svg></div>",
    "quiz": {
      "q": "What must be monitored closely after starting insulin in DKA?",
      "a": "Potassium."
    }
  },
  {
    "id": "HY-EM-006",
    "cat": "Emergency",
    "sub": "Cardiac Arrest",
    "title": "⚡ CARDIAC ARREST RHYTHMS",
    "content": "Four rhythms must be recognized immediately in emergency medicine.<br><br><span class=\"hl-red\">Shockable rhythms</span><br>• Ventricular fibrillation<br>• Pulseless ventricular tachycardia<br><br><span class=\"hl-blue\">Non-shockable rhythms</span><br>• Asystole<br>• Pulseless electrical activity<br><br><div style=\"overflow-x:auto;\"><table><thead><tr><th>Rhythm</th><th>Shockable</th><th>Main treatment</th></tr></thead><tbody><tr><td>Ventricular fibrillation</td><td>Yes</td><td>Defibrillation + CPR</td></tr><tr><td>Pulseless VT</td><td>Yes</td><td>Defibrillation + CPR</td></tr><tr><td>Asystole</td><td>No</td><td>CPR + Epinephrine</td></tr><tr><td>PEA</td><td>No</td><td>CPR + Treat reversible cause</td></tr></tbody></table></div><br><div style=\"border:1px solid #e5e7eb;border-radius:12px;padding:14px;background:#fff;\"><b>Rapid logic</b><br><br><svg viewBox=\"0 0 700 220\" width=\"100%\" height=\"220\" xmlns=\"http://www.w3.org/2000/svg\"><rect x=\"220\" y=\"10\" width=\"260\" height=\"50\" rx=\"12\" fill=\"#0f172a\"/><text x=\"350\" y=\"42\" text-anchor=\"middle\" font-size=\"20\" fill=\"white\">Cardiac arrest rhythm</text><line x1=\"350\" y1=\"60\" x2=\"350\" y2=\"95\" stroke=\"#475569\" stroke-width=\"3\"/><rect x=\"80\" y=\"95\" width=\"220\" height=\"60\" rx=\"12\" fill=\"#fee2e2\" stroke=\"#ef4444\"/><text x=\"190\" y=\"128\" text-anchor=\"middle\" font-size=\"18\" fill=\"#991b1b\">VF / Pulseless VT</text><text x=\"190\" y=\"148\" text-anchor=\"middle\" font-size=\"15\" fill=\"#991b1b\">Shock now</text><rect x=\"400\" y=\"95\" width=\"220\" height=\"60\" rx=\"12\" fill=\"#dbeafe\" stroke=\"#2563eb\"/><text x=\"510\" y=\"128\" text-anchor=\"middle\" font-size=\"18\" fill=\"#1d4ed8\">Asystole / PEA</text><text x=\"510\" y=\"148\" text-anchor=\"middle\" font-size=\"15\" fill=\"#1d4ed8\">No shock</text></svg></div>",
    "quiz": {
      "q": "Which cardiac arrest rhythms require defibrillation?",
      "a": "Ventricular fibrillation and pulseless ventricular tachycardia."
    }
  },
  {
    "id": "HY-EM-007",
    "cat": "Emergency",
    "sub": "Toxicology",
    "title": "☠️ OPIOID OVERDOSE",
    "content": "Classic opioid toxicity must be recognized rapidly.<br><br><span class=\"hl-red\">Classic triad</span><br>• Decreased consciousness<br>• Respiratory depression<br>• Pinpoint pupils<br><br><div style=\"overflow-x:auto;\"><table><thead><tr><th>Finding</th><th>Meaning</th></tr></thead><tbody><tr><td>Slow breathing</td><td>Respiratory center suppression</td></tr><tr><td>Miosis</td><td>Opioid effect</td></tr><tr><td>Low consciousness</td><td>CNS depression</td></tr></tbody></table></div><br><span class=\"hl-green\">Treatment</span><br>• Naloxone<br>• Airway support<br>• Oxygen<br><br><div style=\"border:1px solid #e5e7eb;border-radius:12px;padding:14px;background:#f8fbff;\"><b>Decision strip</b><br><br><svg viewBox=\"0 0 700 190\" width=\"100%\" height=\"190\" xmlns=\"http://www.w3.org/2000/svg\"><rect x=\"40\" y=\"60\" width=\"180\" height=\"60\" rx=\"12\" fill=\"#fee2e2\" stroke=\"#ef4444\"/><text x=\"130\" y=\"95\" text-anchor=\"middle\" font-size=\"18\" fill=\"#991b1b\">Low RR + pinpoint pupils</text><line x1=\"220\" y1=\"90\" x2=\"350\" y2=\"90\" stroke=\"#475569\" stroke-width=\"4\"/><polygon points=\"350,90 330,80 330,100\" fill=\"#475569\"/><rect x=\"350\" y=\"60\" width=\"130\" height=\"60\" rx=\"12\" fill=\"#dbeafe\" stroke=\"#2563eb\"/><text x=\"415\" y=\"95\" text-anchor=\"middle\" font-size=\"18\" fill=\"#1d4ed8\">Naloxone</text><line x1=\"480\" y1=\"90\" x2=\"620\" y2=\"90\" stroke=\"#475569\" stroke-width=\"4\"/><polygon points=\"620,90 600,80 600,100\" fill=\"#475569\"/><rect x=\"520\" y=\"20\" width=\"140\" height=\"60\" rx=\"12\" fill=\"#dcfce7\" stroke=\"#16a34a\"/><text x=\"590\" y=\"55\" text-anchor=\"middle\" font-size=\"18\" fill=\"#166534\">Breathing improves</text><rect x=\"520\" y=\"110\" width=\"140\" height=\"60\" rx=\"12\" fill=\"#fef3c7\" stroke=\"#f59e0b\"/><text x=\"590\" y=\"145\" text-anchor=\"middle\" font-size=\"18\" fill=\"#92400e\">Need airway support</text></svg></div>",
    "quiz": {
      "q": "What medication reverses opioid overdose?",
      "a": "Naloxone."
    }
  },
  {
    "id": "HY-EM-008",
    "cat": "Emergency",
    "sub": "Neurology",
    "title": "🧠 STROKE EMERGENCY",
    "content": "Time is brain. Early treatment improves outcome.<br><br><span class=\"hl-red\">Common symptoms</span><br>• Sudden weakness<br>• Speech difficulty<br>• Facial droop<br>• Vision loss<br><br><div style=\"overflow-x:auto;\"><table><thead><tr><th>FAST</th><th>Meaning</th></tr></thead><tbody><tr><td>Face</td><td>Facial droop</td></tr><tr><td>Arm</td><td>Arm weakness</td></tr><tr><td>Speech</td><td>Speech difficulty</td></tr><tr><td>Time</td><td>Emergency response now</td></tr></tbody></table></div><br><span class=\"hl-blue\">Key step</span><br>Immediate CT scan to rule out hemorrhage.<br><br><div style=\"border:1px solid #e5e7eb;border-radius:12px;padding:14px;background:#fff;\"><b>Stroke pathway</b><br><br><svg viewBox=\"0 0 700 260\" width=\"100%\" height=\"260\" xmlns=\"http://www.w3.org/2000/svg\"><rect x=\"220\" y=\"10\" width=\"260\" height=\"50\" rx=\"12\" fill=\"#0f172a\"/><text x=\"350\" y=\"42\" text-anchor=\"middle\" font-size=\"20\" fill=\"white\">Suspected acute stroke</text><line x1=\"350\" y1=\"60\" x2=\"350\" y2=\"95\" stroke=\"#475569\" stroke-width=\"3\"/><rect x=\"245\" y=\"95\" width=\"210\" height=\"50\" rx=\"12\" fill=\"#dbeafe\" stroke=\"#2563eb\"/><text x=\"350\" y=\"127\" text-anchor=\"middle\" font-size=\"18\" fill=\"#1d4ed8\">CT brain</text><line x1=\"350\" y1=\"145\" x2=\"220\" y2=\"190\" stroke=\"#475569\" stroke-width=\"3\"/><line x1=\"350\" y1=\"145\" x2=\"480\" y2=\"190\" stroke=\"#475569\" stroke-width=\"3\"/><rect x=\"80\" y=\"190\" width=\"220\" height=\"50\" rx=\"12\" fill=\"#fee2e2\" stroke=\"#ef4444\"/><text x=\"190\" y=\"222\" text-anchor=\"middle\" font-size=\"18\" fill=\"#991b1b\">Hemorrhage → no tPA</text><rect x=\"400\" y=\"190\" width=\"220\" height=\"50\" rx=\"12\" fill=\"#dcfce7\" stroke=\"#16a34a\"/><text x=\"510\" y=\"222\" text-anchor=\"middle\" font-size=\"18\" fill=\"#166534\">Ischemic → consider reperfusion</text></svg></div>",
    "quiz": {
      "q": "What imaging must be done first in suspected stroke?",
      "a": "Non-contrast CT of the brain."
    }
  },
  {
    "id": "HY-EM-009",
    "cat": "Emergency",
    "sub": "Respiratory",
    "title": "🫁 ACUTE ASTHMA ATTACK",
    "content": "Acute asthma exacerbation presents with airway narrowing.<br><br><span class=\"hl-red\">Symptoms</span><br>• Wheezing<br>• Dyspnea<br>• Chest tightness<br>• Cough<br><br><div style=\"overflow-x:auto;\"><table><thead><tr><th>Severity</th><th>Typical finding</th></tr></thead><tbody><tr><td>Mild</td><td>Speaks full sentences</td></tr><tr><td>Moderate</td><td>Speaks phrases</td></tr><tr><td>Severe</td><td>Speaks single words or cannot complete sentences</td></tr></tbody></table></div><br><span class=\"hl-green\">Treatment</span><br>• Oxygen if needed<br>• Short acting beta agonist<br>• Steroids<br><br><div style=\"border:1px solid #e5e7eb;border-radius:12px;padding:14px;background:#f8fbff;\"><b>Severity logic</b><br><br><svg viewBox=\"0 0 700 180\" width=\"100%\" height=\"180\" xmlns=\"http://www.w3.org/2000/svg\"><rect x=\"40\" y=\"60\" width=\"170\" height=\"60\" rx=\"12\" fill=\"#dcfce7\" stroke=\"#16a34a\"/><text x=\"125\" y=\"95\" text-anchor=\"middle\" font-size=\"18\" fill=\"#166534\">Mild</text><line x1=\"210\" y1=\"90\" x2=\"280\" y2=\"90\" stroke=\"#475569\" stroke-width=\"4\"/><rect x=\"280\" y=\"60\" width=\"170\" height=\"60\" rx=\"12\" fill=\"#fef3c7\" stroke=\"#f59e0b\"/><text x=\"365\" y=\"95\" text-anchor=\"middle\" font-size=\"18\" fill=\"#92400e\">Moderate</text><line x1=\"450\" y1=\"90\" x2=\"520\" y2=\"90\" stroke=\"#475569\" stroke-width=\"4\"/><rect x=\"520\" y=\"60\" width=\"140\" height=\"60\" rx=\"12\" fill=\"#fee2e2\" stroke=\"#ef4444\"/><text x=\"590\" y=\"95\" text-anchor=\"middle\" font-size=\"18\" fill=\"#991b1b\">Severe</text></svg></div>",
    "quiz": {
      "q": "What is the first bronchodilator used in acute asthma?",
      "a": "Short acting beta agonist such as salbutamol."
    }
  },
  {
    "id": "HY-EM-010",
    "cat": "Emergency",
    "sub": "Allergy",
    "title": "⚠️ ANAPHYLAXIS",
    "content": "A life-threatening systemic allergic reaction.<br><br><span class=\"hl-red\">Common triggers</span><br>• Food<br>• Drugs<br>• Insect stings<br><br><div style=\"overflow-x:auto;\"><table><thead><tr><th>System</th><th>Symptoms</th></tr></thead><tbody><tr><td>Skin</td><td>Urticaria, itching</td></tr><tr><td>Respiratory</td><td>Wheezing, throat swelling</td></tr><tr><td>Cardiovascular</td><td>Hypotension</td></tr></tbody></table></div><br><span class=\"hl-green\">Immediate treatment</span><br>Intramuscular epinephrine.<br><br><div style=\"border:1px solid #e5e7eb;border-radius:12px;padding:14px;background:#fff;\"><b>Emergency flow</b><br><br><svg viewBox=\"0 0 700 220\" width=\"100%\" height=\"220\" xmlns=\"http://www.w3.org/2000/svg\"><rect x=\"190\" y=\"10\" width=\"320\" height=\"50\" rx=\"12\" fill=\"#fee2e2\" stroke=\"#ef4444\"/><text x=\"350\" y=\"42\" text-anchor=\"middle\" font-size=\"20\" fill=\"#991b1b\">Airway swelling / wheeze / hypotension</text><line x1=\"350\" y1=\"60\" x2=\"350\" y2=\"100\" stroke=\"#475569\" stroke-width=\"3\"/><rect x=\"260\" y=\"100\" width=\"180\" height=\"50\" rx=\"12\" fill=\"#dcfce7\" stroke=\"#16a34a\"/><text x=\"350\" y=\"132\" text-anchor=\"middle\" font-size=\"20\" fill=\"#166534\">IM epinephrine</text><line x1=\"350\" y1=\"150\" x2=\"350\" y2=\"190\" stroke=\"#475569\" stroke-width=\"3\"/><rect x=\"160\" y=\"190\" width=\"380\" height=\"25\" rx=\"10\" fill=\"#dbeafe\" stroke=\"#2563eb\"/><text x=\"350\" y=\"207\" text-anchor=\"middle\" font-size=\"14\" fill=\"#1d4ed8\">Then oxygen, IV fluids, antihistamine, steroid as adjuncts</text></svg></div>",
    "quiz": {
      "q": "What is the first line treatment for anaphylaxis?",
      "a": "Intramuscular epinephrine."
    }
  },
  {
    "id": "HY-EM-011",
    "cat": "Emergency",
    "sub": "Cardiology",
    "title": "❤️ ACUTE MI",
    "content": "Think acute myocardial infarction in any high-risk patient with ischemic chest pain.<br><br><span class=\"hl-red\">Classic symptoms</span><br>• Crushing chest pain<br>• Radiation to arm or jaw<br>• Sweating<br>• Nausea<br>• Dyspnea<br><br><div style=\"overflow-x:auto;\"><table><thead><tr><th>Immediate step</th><th>Reason</th></tr></thead><tbody><tr><td>ECG</td><td>Look for STEMI/NSTEMI pattern</td></tr><tr><td>Troponin</td><td>Detect myocardial injury</td></tr><tr><td>Aspirin</td><td>Early antiplatelet effect</td></tr><tr><td>Reperfusion if STEMI</td><td>Restore blood flow</td></tr></tbody></table></div><br><div style=\"border:1px solid #e5e7eb;border-radius:12px;padding:14px;background:#f8fbff;\"><b>MI sequence</b><br><br><svg viewBox=\"0 0 700 170\" width=\"100%\" height=\"170\" xmlns=\"http://www.w3.org/2000/svg\"><rect x=\"40\" y=\"55\" width=\"150\" height=\"55\" rx=\"12\" fill=\"#fee2e2\" stroke=\"#ef4444\"/><text x=\"115\" y=\"88\" text-anchor=\"middle\" font-size=\"18\" fill=\"#991b1b\">Chest pain</text><line x1=\"190\" y1=\"82\" x2=\"280\" y2=\"82\" stroke=\"#475569\" stroke-width=\"4\"/><rect x=\"280\" y=\"55\" width=\"140\" height=\"55\" rx=\"12\" fill=\"#dbeafe\" stroke=\"#2563eb\"/><text x=\"350\" y=\"88\" text-anchor=\"middle\" font-size=\"18\" fill=\"#1d4ed8\">ECG + Troponin</text><line x1=\"420\" y1=\"82\" x2=\"520\" y2=\"82\" stroke=\"#475569\" stroke-width=\"4\"/><rect x=\"520\" y=\"55\" width=\"140\" height=\"55\" rx=\"12\" fill=\"#dcfce7\" stroke=\"#16a34a\"/><text x=\"590\" y=\"88\" text-anchor=\"middle\" font-size=\"18\" fill=\"#166534\">Reperfusion</text></svg></div>",
    "quiz": {
      "q": "What is the first investigation in suspected acute MI?",
      "a": "ECG."
    }
  },
  {
    "id": "HY-EM-012",
    "cat": "Emergency",
    "sub": "Cardiology",
    "title": "💥 AORTIC DISSECTION",
    "content": "This is one of the most dangerous causes of chest pain.<br><br><span class=\"hl-red\">Classic clue</span><br>Sudden tearing chest pain radiating to the back.<br><br><span class=\"hl-blue\">Other clues</span><br>• Hypertension history<br>• Pulse deficit<br>• BP difference between arms<br>• New aortic regurgitation murmur may occur<br><br><div style=\"overflow-x:auto;\"><table><thead><tr><th>Feature</th><th>Dissection clue</th></tr></thead><tbody><tr><td>Pain</td><td>Tearing, abrupt onset</td></tr><tr><td>Radiation</td><td>To back</td></tr><tr><td>Vitals</td><td>May have severe hypertension or shock</td></tr><tr><td>Action</td><td>Urgent imaging and blood pressure control</td></tr></tbody></table></div><br><div style=\"border:1px solid #e5e7eb;border-radius:12px;padding:14px;background:#fff;\"><b>Quick differentiator</b><br><br><svg viewBox=\"0 0 700 170\" width=\"100%\" height=\"170\" xmlns=\"http://www.w3.org/2000/svg\"><rect x=\"70\" y=\"55\" width=\"220\" height=\"60\" rx=\"12\" fill=\"#fee2e2\" stroke=\"#ef4444\"/><text x=\"180\" y=\"90\" text-anchor=\"middle\" font-size=\"18\" fill=\"#991b1b\">Tearing pain to back</text><line x1=\"290\" y1=\"85\" x2=\"410\" y2=\"85\" stroke=\"#475569\" stroke-width=\"4\"/><rect x=\"410\" y=\"55\" width=\"220\" height=\"60\" rx=\"12\" fill=\"#dbeafe\" stroke=\"#2563eb\"/><text x=\"520\" y=\"90\" text-anchor=\"middle\" font-size=\"18\" fill=\"#1d4ed8\">Think dissection urgently</text></svg></div>",
    "quiz": {
      "q": "What pain description is classic for aortic dissection?",
      "a": "Sudden tearing chest pain radiating to the back."
    }
  },
  {
    "id": "HY-EM-013",
    "cat": "Emergency",
    "sub": "Respiratory",
    "title": "🫀 PULMONARY EMBOLISM",
    "content": "Pulmonary embolism must be considered in unexplained sudden dyspnea.<br><br><span class=\"hl-red\">Typical features</span><br>• Sudden shortness of breath<br>• Pleuritic chest pain<br>• Tachycardia<br>• Hypoxia<br><br><span class=\"hl-blue\">Risk factors</span><br>• Immobility<br>• Recent surgery<br>• Cancer<br>• Pregnancy<br>• Previous DVT/PE<br><br><div style=\"overflow-x:auto;\"><table><thead><tr><th>Clinical clue</th><th>Meaning</th></tr></thead><tbody><tr><td>Sudden dyspnea</td><td>Common presentation</td></tr><tr><td>Pleuritic pain</td><td>Lung infarct or pleural irritation</td></tr><tr><td>Tachycardia</td><td>Frequent sign</td></tr><tr><td>Risk factors present</td><td>Raises probability</td></tr></tbody></table></div><br><div style=\"border:1px solid #e5e7eb;border-radius:12px;padding:14px;background:#f8fbff;\"><b>PE thought path</b><br><br><svg viewBox=\"0 0 700 220\" width=\"100%\" height=\"220\" xmlns=\"http://www.w3.org/2000/svg\"><rect x=\"180\" y=\"10\" width=\"340\" height=\"50\" rx=\"12\" fill=\"#fee2e2\" stroke=\"#ef4444\"/><text x=\"350\" y=\"42\" text-anchor=\"middle\" font-size=\"20\" fill=\"#991b1b\">Sudden dyspnea + pleuritic pain</text><line x1=\"350\" y1=\"60\" x2=\"350\" y2=\"100\" stroke=\"#475569\" stroke-width=\"3\"/><rect x=\"220\" y=\"100\" width=\"260\" height=\"50\" rx=\"12\" fill=\"#dbeafe\" stroke=\"#2563eb\"/><text x=\"350\" y=\"132\" text-anchor=\"middle\" font-size=\"18\" fill=\"#1d4ed8\">Check probability / D-dimer / imaging</text><line x1=\"350\" y1=\"150\" x2=\"350\" y2=\"190\" stroke=\"#475569\" stroke-width=\"3\"/><rect x=\"230\" y=\"190\" width=\"240\" height=\"25\" rx=\"10\" fill=\"#dcfce7\" stroke=\"#16a34a\"/><text x=\"350\" y=\"207\" text-anchor=\"middle\" font-size=\"14\" fill=\"#166534\">Anticoagulate if confirmed or highly suspected</text></svg></div>",
    "quiz": {
      "q": "What imaging is commonly used to confirm pulmonary embolism?",
      "a": "CT pulmonary angiography."
    }
  },
  {
    "id": "HY-EM-014",
    "cat": "Emergency",
    "sub": "Gastrointestinal",
    "title": "🩸 UPPER GI BLEED",
    "content": "Upper GI bleeding is an emergency when hemodynamic instability is present.<br><br><span class=\"hl-red\">Key findings</span><br>• Hematemesis<br>• Melena<br>• Dizziness or syncope<br>• Hypotension if severe<br><br><span class=\"hl-green\">Immediate priorities</span><br>• ABCs<br>• Large-bore IV access<br>• Fluids and blood if needed<br>• PPI<br>• Endoscopy once stabilized<br><br><div style=\"overflow-x:auto;\"><table><thead><tr><th>Feature</th><th>Interpretation</th></tr></thead><tbody><tr><td>Hematemesis</td><td>Upper GI source likely</td></tr><tr><td>Melena</td><td>Digested blood</td></tr><tr><td>Shock signs</td><td>Severe blood loss</td></tr><tr><td>Management</td><td>Resuscitate before scope</td></tr></tbody></table></div><br><div style=\"border:1px solid #e5e7eb;border-radius:12px;padding:14px;background:#fff;\"><b>Resuscitation flow</b><br><br><svg viewBox=\"0 0 700 170\" width=\"100%\" height=\"170\" xmlns=\"http://www.w3.org/2000/svg\"><rect x=\"40\" y=\"55\" width=\"170\" height=\"60\" rx=\"12\" fill=\"#fee2e2\" stroke=\"#ef4444\"/><text x=\"125\" y=\"90\" text-anchor=\"middle\" font-size=\"18\" fill=\"#991b1b\">Hematemesis / melena</text><line x1=\"210\" y1=\"85\" x2=\"300\" y2=\"85\" stroke=\"#475569\" stroke-width=\"4\"/><rect x=\"300\" y=\"55\" width=\"120\" height=\"60\" rx=\"12\" fill=\"#dbeafe\" stroke=\"#2563eb\"/><text x=\"360\" y=\"90\" text-anchor=\"middle\" font-size=\"18\" fill=\"#1d4ed8\">Resuscitate</text><line x1=\"420\" y1=\"85\" x2=\"520\" y2=\"85\" stroke=\"#475569\" stroke-width=\"4\"/><rect x=\"520\" y=\"55\" width=\"140\" height=\"60\" rx=\"12\" fill=\"#dcfce7\" stroke=\"#16a34a\"/><text x=\"590\" y=\"90\" text-anchor=\"middle\" font-size=\"18\" fill=\"#166534\">Endoscopy</text></svg></div>",
    "quiz": {
      "q": "What comes first in an unstable upper GI bleed, endoscopy or resuscitation?",
      "a": "Resuscitation comes first."
    }
  },
  {
    "id": "HY-EM-015",
    "cat": "Emergency",
    "sub": "Neurology",
    "title": "⚠️ STATUS EPILEPTICUS",
    "content": "Status epilepticus is a true emergency because prolonged seizures injure the brain.<br><br><span class=\"hl-red\">Definition</span><br>Seizure lasting more than 5 minutes or repeated seizures without return to baseline.<br><br><span class=\"hl-green\">First treatment</span><br>• Benzodiazepine such as lorazepam<br>• Then second-line anti-seizure therapy if needed<br><br><div style=\"overflow-x:auto;\"><table><thead><tr><th>Step</th><th>Treatment</th></tr></thead><tbody><tr><td>First</td><td>Airway, oxygen, glucose check</td></tr><tr><td>Second</td><td>Lorazepam</td></tr><tr><td>Third</td><td>Longer-acting anti-seizure medication</td></tr></tbody></table></div><br><div style=\"border:1px solid #e5e7eb;border-radius:12px;padding:14px;background:#f8fbff;\"><b>Emergency sequence</b><br><br><svg viewBox=\"0 0 700 180\" width=\"100%\" height=\"180\" xmlns=\"http://www.w3.org/2000/svg\"><rect x=\"40\" y=\"60\" width=\"180\" height=\"60\" rx=\"12\" fill=\"#fee2e2\" stroke=\"#ef4444\"/><text x=\"130\" y=\"95\" text-anchor=\"middle\" font-size=\"18\" fill=\"#991b1b\">Seizure &gt; 5 min</text><line x1=\"220\" y1=\"90\" x2=\"310\" y2=\"90\" stroke=\"#475569\" stroke-width=\"4\"/><rect x=\"310\" y=\"60\" width=\"120\" height=\"60\" rx=\"12\" fill=\"#dbeafe\" stroke=\"#2563eb\"/><text x=\"370\" y=\"95\" text-anchor=\"middle\" font-size=\"18\" fill=\"#1d4ed8\">Lorazepam</text><line x1=\"430\" y1=\"90\" x2=\"530\" y2=\"90\" stroke=\"#475569\" stroke-width=\"4\"/><rect x=\"530\" y=\"60\" width=\"130\" height=\"60\" rx=\"12\" fill=\"#dcfce7\" stroke=\"#16a34a\"/><text x=\"595\" y=\"95\" text-anchor=\"middle\" font-size=\"18\" fill=\"#166534\">Escalate if needed</text></svg></div>",
    "quiz": {
      "q": "What is the first medication class used in status epilepticus?",
      "a": "Benzodiazepines."
    }
  }
]
